# -----------------------------------------------------------------------
# rag-eval-harness environment variables
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The default config (groq_llama4.yaml) only needs GROQ_API_KEY
# and COHERE_API_KEY — both are free tier.
# -----------------------------------------------------------------------

# Groq API — free tier: https://console.groq.com
# Used by: configs/groq_llama4.yaml (default)
GROQ_API_KEY=your_groq_api_key_here

# Cohere — free tier: https://cohere.com (1,000 reranks/month)
# Used by: all configs for the rerank strategy
COHERE_API_KEY=your_cohere_api_key_here

# -----------------------------------------------------------------------
# Optional — only needed if using non-default configs
# -----------------------------------------------------------------------

# OpenAI — https://platform.openai.com
# Used by: configs/openai.yaml
# Install: uv sync --extra openai
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — https://www.anthropic.com
# Used by: custom configs with provider: anthropic
# Install: uv sync --extra anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI Studio — free tier: https://aistudio.google.com
# Used by: configs/google_gemini.yaml
# Install: uv sync --extra google
# GOOGLE_API_KEY=your_google_api_key_here

# Ollama — runs locally, no key needed
# Used by: configs/ollama_local.yaml
# Install Ollama: https://ollama.com
# Install extra: uv sync --extra ollama
# OLLAMA_BASE_URL=http://localhost:11434
